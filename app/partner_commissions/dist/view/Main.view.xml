<mvc:View controllerName="partnercommissions.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:u="sap.ui.unified">

    <tnt:ToolPage id="toolPage">

        <tnt:header>
            <tnt:ToolHeader id="toolHeader">
                <Button id="sideNavToggleBtn" icon="sap-icon://menu2" press="onToggleSideNav" type="Transparent" />
                <Title id="appTitleHeader" text="{i18n>appTitle}" level="H4" />
            </tnt:ToolHeader>
        </tnt:header>

        <tnt:sideContent>
            <tnt:SideNavigation id="sideNav" selectedKey="partnerOnboarding" itemSelect="onSideNavItemSelect">
                <tnt:NavigationList id="mainNavList">
                    <tnt:NavigationListItem id="navItemDashboard" text="{i18n>navDashboard}" icon="sap-icon://home" key="dashboard" />
                    <tnt:NavigationListItem id="navItemPartnerOnboarding" text="{i18n>navPartnerOnboarding}" icon="sap-icon://add-employee" key="partnerOnboarding" />
                    <tnt:NavigationListItem id="navItemPartnerAnalytics" text="{i18n>navPartnerAnalytics}" icon="sap-icon://business-objects-experience" key="partnerAnalytics" />
                    <tnt:NavigationListItem id="navItemIncentiveProgram" text="{i18n>navIncentiveProgramSetup}" icon="sap-icon://competitor" key="incentiveProgramSetup" />
                    <tnt:NavigationListItem id="navItemPartnerAssignment" text="{i18n>navPartnerAssignment}" icon="sap-icon://collaborate" key="partnerAssignment" />
                    <tnt:NavigationListItem id="navItemPartnerHierarchy" text="{i18n>navPartnerHierarchySetup}" icon="sap-icon://org-chart" key="partnerHierarchySetup" />
                    <tnt:NavigationListItem id="navItemRiskScreening" text="{i18n>navRiskScreening}" icon="sap-icon://alert" key="riskScreening" />
                    <tnt:NavigationListItem id="navItemPaymentSchedule" text="{i18n>navPaymentScheduleSetup}" icon="sap-icon://date-time" key="paymentScheduleSetup" />
                    <tnt:NavigationListItem id="navItemDealRegistration" text="{i18n>navDealRegistration}" icon="sap-icon://sales-document" key="dealRegistration" />
                    <tnt:NavigationListItem id="navItemPaymentApproval" text="{i18n>navPaymentApproval}" icon="sap-icon://accept" key="paymentApproval" />
                </tnt:NavigationList>
                <tnt:fixedItem>
                    <tnt:NavigationList id="fixedNavList">
                        <tnt:NavigationListItem id="navItemConfigurations" text="{i18n>navConfigurations}" icon="sap-icon://wrench" expanded="false">
                            <tnt:NavigationListItem id="navItemConfigDataSources" text="{i18n>navDataSources}" icon="sap-icon://database" key="configDataSources" />
                            <tnt:NavigationListItem id="navItemConfigCustomizations" text="{i18n>navCustomizations}" icon="sap-icon://customize" key="configCustomizations" />
                        </tnt:NavigationListItem>
                        <tnt:NavigationListItem id="navItemSettings" text="{i18n>navSettings}" icon="sap-icon://action-settings" key="settings" />
                    </tnt:NavigationList>
                </tnt:fixedItem>
            </tnt:SideNavigation>
        </tnt:sideContent>

        <tnt:mainContents>
            <NavContainer id="mainContent">

                <!-- Partner Onboarding Page -->
                <Page id="partnerOnboardingPage" showHeader="false">
                    <content>
                        <VBox id="partnerOnboardingHeaderVBox">
                            <HBox id="partnerOnboardingHeaderHBox" class="sapUiSmallMargin" alignItems="Center">
                                <core:Icon id="partnerOnboardingIcon" src="sap-icon://add-employee" size="2rem" class="sapUiSmallMarginEnd" />
                                <Title id="partnerOnboardingTitle" text="{i18n>partnerOnboardingTitle}" level="H2" />
                            </HBox>
                            <Text id="partnerOnboardingDesc" text="{i18n>partnerOnboardingDescription}" class="sapUiSmallMarginBegin sapUiSmallMarginBottom" />
                        </VBox>
                        <OverflowToolbar id="partnerTableToolbar">
                            <Title id="partnerTableTitle" text="Partners (0)" level="H5" />
                            <ToolbarSpacer id="partnerTableToolbarSpacer" />
                            <Button id="btnRegisterPartner" text="{i18n>btnRegisterNewPartner}" icon="sap-icon://add" press="onRegisterPartner" type="Emphasized" />
                            <MenuButton id="btnBulkOnboarding" text="{i18n>btnBulkPartnerOnboarding}" type="Ghost" icon="sap-icon://upload-to-cloud">
                                <menu>
                                    <Menu id="bulkOnboardingMenu">
                                        <MenuItem id="menuDownloadTemplate" text="{i18n>btnDownloadTemplate}" icon="sap-icon://download" press="onDownloadTemplate" />
                                        <MenuItem id="menuUploadTemplate" text="{i18n>btnUploadTemplate}" icon="sap-icon://upload" press="onUploadTemplate" />
                                    </Menu>
                                </menu>
                            </MenuButton>
                            <Button id="btnColumnSettings" icon="sap-icon://action-settings" press="onOpenColumnSettings" type="Transparent" tooltip="{i18n>btnColumnSettings}" />
                        </OverflowToolbar>
                        <Table id="tblPartners" growing="true" growingThreshold="50">
                            <noData>
                                <IllustratedMessage id="partnersEmptyIllustration" illustrationType="sapIllus-AddColumn" title="{i18n>noPartnersTitle}" description="{i18n>noPartnersDesc}" />
                            </noData>
                        </Table>
                    </content>
                </Page>

                <!-- Partner Analytics Page -->
                <Page id="partnerAnalyticsPage" showHeader="false">
                    <content>
                        <VBox id="partnerAnalyticsHeaderVBox">
                            <HBox id="partnerAnalyticsHeaderHBox" class="sapUiSmallMargin" alignItems="Center">
                                <core:Icon id="partnerAnalyticsIcon" src="sap-icon://business-objects-experience" size="2rem" class="sapUiSmallMarginEnd" />
                                <Title id="partnerAnalyticsTitle" text="{i18n>partnerAnalyticsTitle}" level="H2" />
                            </HBox>
                            <Text id="partnerAnalyticsDesc" text="{i18n>partnerAnalyticsDescription}" class="sapUiSmallMarginBegin sapUiSmallMarginBottom" />
                        </VBox>
                        <OverflowToolbar id="analyticsFilterToolbar" class="sapUiSmallMarginTop">
                            <core:Icon id="analyticsFilterIcon" src="sap-icon://filter" />
                            <Title id="analyticsFilterTitle" text="{i18n>lblFilters}" level="H5" />
                            <ToolbarSpacer id="analyticsFilterSpacer" />
                            <Button id="btnAnalyticsGo" text="{i18n>btnGo}" type="Emphasized" icon="sap-icon://search" press="onAnalyticsGo" />
                        </OverflowToolbar>
                        <HBox id="analyticsFilterBar" wrap="Wrap" class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiTinyMarginTop" alignItems="End">
                            <VBox id="filterGroupPeriod" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                                <Label id="lblAnalyticsPeriod" text="{i18n>lblSelectPeriod}" />
                                <MultiComboBox id="cmbAnalyticsPeriods" placeholder="{i18n>phSelectPeriod}" width="16rem"
                                    items="{periodsData>/}" showSecondaryValues="true">
                                    <items>
                                        <core:ListItem id="cmbAnalyticsPeriodsItem" key="{periodsData>PERIODSEQ}" text="{periodsData>NAME}" additionalText="{periodsData>PERIOD_RANGE}" />
                                    </items>
                                </MultiComboBox>
                            </VBox>
                            <VBox id="filterGroupProduct" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                                <Label id="lblAnalyticsProduct" text="{i18n>lblProductId}" />
                                <MultiComboBox id="cmbAnalyticsProducts" placeholder="{i18n>phSelectProduct}" width="16rem"
                                    items="{productsData>/}" showSecondaryValues="true">
                                    <items>
                                        <core:ListItem id="cmbAnalyticsProductsItem" key="{productsData>PRODUCTID}" text="{productsData>PRODUCTID}" additionalText="{productsData>PRODUCTNAME}" />
                                    </items>
                                </MultiComboBox>
                            </VBox>
                            <VBox id="filterGroupCreditType" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                                <Label id="lblAnalyticsCreditType" text="{i18n>lblCreditType}" />
                                <MultiComboBox id="cmbAnalyticsCreditTypes" placeholder="{i18n>phSelectCreditType}" width="16rem"
                                    items="{creditTypesData>/}">
                                    <items>
                                        <core:Item id="cmbAnalyticsCreditTypesItem" key="{creditTypesData>CREDITTYPEID}" text="{creditTypesData>CREDITTYPEID}" />
                                    </items>
                                </MultiComboBox>
                            </VBox>
                            <VBox id="filterGroupCompDate" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                                <Label id="lblAnalyticsCompDate" text="{i18n>lblCompensationDate}" />
                                <DateRangeSelection id="drsAnalyticsCompDate" placeholder="{i18n>phSelectCompDateRange}" width="16rem" />
                            </VBox>
                            <VBox id="filterGroupCustomer" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                                <Label id="lblAnalyticsCustomer" text="{i18n>lblCustomer}" />
                                <ComboBox id="cmbAnalyticsCustomer" placeholder="{i18n>phSelectCustomer}" width="16rem" />
                            </VBox>
                        </HBox>
                        <VBox id="partnerAnalyticsContentVBox" class="sapUiSmallMargin">
                            <OverflowToolbar id="analyticsChartToolbar" visible="{= ${analyticsChartData>/}.length > 0 }">
                                <Label id="lblChartType" text="{i18n>lblChartType}" class="sapUiTinyMarginEnd" />
                                <SegmentedButton id="chartTypeSelector" selectionChange=".onChartTypeChange" selectedKey="{chartConfig>/chartType}">
                                    <items>
                                        <SegmentedButtonItem id="chartTypeColumn" key="column" icon="sap-icon://horizontal-bar-chart" tooltip="{i18n>ttColumnChart}" />
                                        <SegmentedButtonItem id="chartTypeBar" key="bar" icon="sap-icon://horizontal-bar-chart-2" tooltip="{i18n>ttBarChart}" />
                                        <SegmentedButtonItem id="chartTypeLine" key="line" icon="sap-icon://line-chart" tooltip="{i18n>ttLineChart}" />
                                        <SegmentedButtonItem id="chartTypeArea" key="area" icon="sap-icon://area-chart" tooltip="{i18n>ttAreaChart}" />
                                        <SegmentedButtonItem id="chartTypePie" key="pie" icon="sap-icon://pie-chart" tooltip="{i18n>ttPieChart}" />
                                        <SegmentedButtonItem id="chartTypeDonut" key="donut" icon="sap-icon://donut-chart" tooltip="{i18n>ttDonutChart}" />
                                    </items>
                                </SegmentedButton>
                                <ToolbarSeparator id="chartSep1" class="sapUiSmallMarginBegin sapUiSmallMarginEnd" />
                                <Label id="lblDimension" text="{i18n>lblDimension}" class="sapUiTinyMarginEnd" />
                                <Select id="chartDimensionSelector" change=".onChartDimensionChange" selectedKey="{chartConfig>/dimension}" width="180px">
                                    <items>
                                        <core:Item id="dimProduct" key="PRODUCTID" text="{i18n>dimProduct}" />
                                        <core:Item id="dimCreditType" key="CREDITTYPEID" text="{i18n>dimCreditType}" />
                                        <core:Item id="dimCompDate" key="COMPENSATIONDATE" text="{i18n>dimCompensationDate}" />
                                    </items>
                                </Select>
                                <Label id="lblMeasure" text="{i18n>lblMeasure}" class="sapUiTinyMarginBegin sapUiTinyMarginEnd" />
                                <Select id="chartMeasureSelector" change=".onChartMeasureChange" selectedKey="{chartConfig>/measure}" width="180px">
                                    <items>
                                        <core:Item id="measureTxnCount" key="TransactionCount" text="{i18n>measureTransactionCount}" />
                                        <core:Item id="measureAmount" key="Amount" text="{i18n>measureAmount}" />
                                    </items>
                                </Select>
                                <Label id="lblTopN" text="{i18n>lblTopN}" class="sapUiTinyMarginBegin sapUiTinyMarginEnd" />
                                <Select id="chartTopNSelector" change=".onChartTopNChange" selectedKey="{chartConfig>/topN}" width="80px">
                                    <items>
                                        <core:Item id="topN10" key="10" text="10" />
                                        <core:Item id="topN20" key="20" text="20" />
                                        <core:Item id="topN30" key="30" text="30" />
                                        <core:Item id="topN50" key="50" text="50" />
                                        <core:Item id="topNAll" key="all" text="{i18n>topNAll}" />
                                    </items>
                                </Select>
                                <ToolbarSpacer id="chartToolbarSpacer" />
                            </OverflowToolbar>
                            <VBox id="analyticsChartBox" visible="{= ${analyticsChartData>/}.length > 0 }" height="500px" class="sapUiSmallMarginTop" width="100%">
                                <core:HTML id="analyticsChartHtml" content="&lt;canvas id='partnerAnalyticsChart' style='width:100%;height:480px;'&gt;&lt;/canvas&gt;" />
                            </VBox>
                            <IllustratedMessage id="partnerAnalyticsPlaceholder" visible="{= ${analyticsChartData>/}.length === 0 }" illustrationType="sapIllus-EmptyList" title="{i18n>analyticsPlaceholderTitle}" description="{i18n>analyticsPlaceholderDesc}" />
                        </VBox>
                    </content>
                </Page>

                <!-- Placeholder pages for other sections -->
                <Page id="dashboardPage" title="{i18n>navDashboard}">
                    <IllustratedMessage id="dashboardIllustration" illustrationType="sapIllus-EmptyList" title="{i18n>comingSoon}" description="{i18n>dashboardComingSoonDesc}" />
                </Page>
                <Page id="incentiveProgramSetupPage" showHeader="false">
                    <content>
                        <VBox id="incentiveHeaderVBox">
                            <HBox id="incentiveHeaderHBox" class="sapUiSmallMargin" alignItems="Center">
                                <core:Icon id="incentiveHeaderIcon" src="sap-icon://competitor" size="2rem" class="sapUiSmallMarginEnd" />
                                <Title id="incentiveHeaderTitle" text="{i18n>incentiveProgramTitle}" level="H2" />
                            </HBox>
                            <Text id="incentiveHeaderDesc" text="{i18n>incentiveProgramDescription}" class="sapUiSmallMarginBegin sapUiSmallMarginBottom" />
                        </VBox>
                        <OverflowToolbar id="incentiveTableToolbar">
                            <Title id="incentiveTableTitle" text="Programs (0)" level="H5" />
                            <ToolbarSpacer id="incentiveTableToolbarSpacer" />
                            <Button id="btnAddIncentiveRow" text="{i18n>btnAdd}" icon="sap-icon://add" press="onAddIncentiveRow" type="Transparent" />
                            <Button id="btnSaveIncentivePrograms" text="{i18n>btnSave}" icon="sap-icon://save" press="onSaveIncentivePrograms" type="Success" />
                        </OverflowToolbar>
                        <Table id="tblIncentivePrograms" items="{incentivePrograms>/}" growing="true" growingThreshold="50">
                            <noData>
                                <IllustratedMessage id="incentiveProgramsEmptyIllustration" illustrationType="sapIllus-AddColumn" title="{i18n>noIncentiveProgramsTitle}" description="{i18n>noIncentiveProgramsDesc}" />
                            </noData>
                            <columns>
                                <Column id="colIPPlanName">
                                    <Text id="colIPPlanNameHeader" text="{i18n>lblProgramName}" />
                                </Column>
                                <Column id="colIPIncentiveType">
                                    <Text id="colIPIncentiveTypeHeader" text="{i18n>lblIncentiveType}" />
                                </Column>
                                <Column id="colIPEligibleTiers" width="140px">
                                    <Text id="colIPEligibleTiersHeader" text="{i18n>lblEligibleTiers}" />
                                </Column>
                                <Column id="colIPStartDate" width="150px">
                                    <Text id="colIPStartDateHeader" text="{i18n>phStartDate}" />
                                </Column>
                                <Column id="colIPEndDate" width="150px">
                                    <Text id="colIPEndDateHeader" text="{i18n>phEndDate}" />
                                </Column>
                                <Column id="colIPDealStage" width="150px">
                                    <Text id="colIPDealStageHeader" text="{i18n>lblDealStage}" />
                                </Column>
                                <Column id="colIPAttach" width="120px" hAlign="Center" visible="false">
                                    <Text id="colIPAttachHeader" text="{i18n>lblAttachDocuments}" />
                                </Column>
                                <Column id="colIPDelete" width="60px" hAlign="Center">
                                    <Text id="colIPDeleteHeader" text="" />
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem id="rowIncentiveProgram">
                                    <cells>
                                        <ComboBox id="cellIPPlanName" selectedKey="{incentivePrograms>planName}" placeholder="{i18n>phProgramName}" width="100%"
                                            items="{planNames>/}">
                                            <items>
                                                <core:Item id="cellIPPlanNameItem" key="{planNames>key}" text="{planNames>text}" />
                                            </items>
                                        </ComboBox>
                                        <MultiComboBox id="cellIPIncentiveType" selectedKeys="{incentivePrograms>incentiveTypes}" placeholder="{i18n>phIncentiveType}" width="100%"
                                            items="{activeIncentiveTypes>/}">
                                            <items>
                                                <core:Item id="cellIPIncentiveTypeItem" key="{activeIncentiveTypes>key}" text="{activeIncentiveTypes>text}" />
                                            </items>
                                        </MultiComboBox>
                                        <ComboBox id="cellIPEligibleTier" selectedKey="{incentivePrograms>eligibleTier}" placeholder="{i18n>lblEligibleTiers}" width="100%"
                                            items="{eligibleTiersConfig>/}" showSecondaryValues="true">
                                            <items>
                                                <core:ListItem id="cellIPTierItem" key="{eligibleTiersConfig>partnerTier}" text="{eligibleTiersConfig>partnerTier}" additionalText="{eligibleTiersConfig>revenueBand}" />
                                            </items>
                                        </ComboBox>
                                        <DatePicker id="cellIPStartDate" value="{incentivePrograms>startDate}" placeholder="{i18n>phStartDate}" width="100%" />
                                        <DatePicker id="cellIPEndDate" value="{incentivePrograms>endDate}" placeholder="{i18n>phEndDate}" width="100%" />
                                        <ComboBox id="cellIPDealStage" selectedKey="{incentivePrograms>dealStage}" placeholder="{i18n>phDealStage}" width="100%">
                                            <items>
                                                <core:Item id="cellIPDealStageCloseDate" key="closeDate" text="{i18n>dealStageCloseDate}" />
                                            </items>
                                        </ComboBox>
                                        <u:FileUploader id="cellIPFileUpload" name="incentiveDocUpload" buttonOnly="true" icon="sap-icon://upload" buttonText="" style="Transparent" change="onIncentiveFileChange" />
                                        <Button id="cellIPDelete" icon="sap-icon://delete" type="Transparent" press="onDeleteIncentiveRow" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </content>
                </Page>
                <Page id="riskScreeningPage" title="{i18n>navRiskScreening}">
                    <IllustratedMessage id="riskScreeningIllustration" illustrationType="sapIllus-EmptyList" title="{i18n>comingSoon}" description="{i18n>riskScreeningComingSoonDesc}" />
                </Page>
                <Page id="paymentScheduleSetupPage" title="{i18n>navPaymentScheduleSetup}">
                    <IllustratedMessage id="paymentScheduleIllustration" illustrationType="sapIllus-EmptyList" title="{i18n>comingSoon}" description="{i18n>paymentScheduleComingSoonDesc}" />
                </Page>
                <Page id="partnerHierarchySetupPage" title="{i18n>navPartnerHierarchySetup}">
                    <IllustratedMessage id="hierarchyIllustration" illustrationType="sapIllus-EmptyList" title="{i18n>comingSoon}" description="{i18n>hierarchyComingSoonDesc}" />
                </Page>
                <Page id="dealRegistrationPage" title="{i18n>navDealRegistration}">
                    <IllustratedMessage id="dealRegIllustration" illustrationType="sapIllus-EmptyList" title="{i18n>comingSoon}" description="{i18n>dealRegComingSoonDesc}" />
                </Page>
                <Page id="paymentApprovalPage" title="{i18n>navPaymentApproval}">
                    <IllustratedMessage id="paymentApprovalIllustration" illustrationType="sapIllus-EmptyList" title="{i18n>comingSoon}" description="{i18n>paymentApprovalComingSoonDesc}" />
                </Page>
                <Page id="partnerMappingsPage" showHeader="false">
                    <content>
                        <VBox id="partnerAssignmentHeaderVBox">
                            <HBox id="partnerAssignmentHeaderHBox" class="sapUiSmallMargin" alignItems="Center">
                                <core:Icon id="partnerAssignmentIcon" src="sap-icon://collaborate" size="2rem" class="sapUiSmallMarginEnd" />
                                <Title id="partnerAssignmentTitle" text="{i18n>partnerAssignmentTitle}" level="H2" />
                            </HBox>
                            <Text id="partnerAssignmentDesc" text="{i18n>partnerAssignmentDescription}" class="sapUiSmallMarginBegin sapUiSmallMarginBottom" />
                        </VBox>
                        <OverflowToolbar id="partnerAssignmentToolbar">
                            <Title id="partnerAssignmentTableTitle" text="Assignments (0)" level="H5" />
                            <ToolbarSpacer id="partnerAssignmentToolbarSpacer" />
                            <Button id="btnAddAssignmentRow" text="{i18n>btnAdd}" icon="sap-icon://add" press="onAddAssignmentRow" type="Transparent" />
                            <Button id="btnSaveAssignments" text="{i18n>btnSave}" icon="sap-icon://save" press="onSaveAssignments" type="Success" />
                        </OverflowToolbar>
                        <Table id="tblPartnerAssignments" items="{partnerAssignments>/}" growing="true" growingThreshold="50">
                            <noData>
                                <IllustratedMessage id="partnerAssignmentsEmptyIllustration" illustrationType="sapIllus-AddColumn" title="{i18n>noAssignmentsTitle}" description="{i18n>noAssignmentsDesc}" />
                            </noData>
                            <columns>
                                <Column id="colPAPartnerName">
                                    <Text id="colPAPartnerNameHeader" text="{i18n>lblPartnerName}" />
                                </Column>
                                <Column id="colPAIncentivePlan">
                                    <Text id="colPAIncentivePlanHeader" text="{i18n>lblIncentivePlan}" />
                                </Column>
                                <Column id="colPADelete" width="60px" hAlign="Center">
                                    <Text id="colPADeleteHeader" text="" />
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem id="rowPartnerAssignment">
                                    <cells>
                                        <ComboBox id="cellPAPartnerName" selectedKey="{partnerAssignments>partnerName}" placeholder="{i18n>phSelectPartner}" width="100%"
                                            items="{onboardedPartners>/}">
                                            <items>
                                                <core:Item id="cellPAPartnerItem" key="{onboardedPartners>key}" text="{onboardedPartners>text}" />
                                            </items>
                                        </ComboBox>
                                        <ComboBox id="cellPAIncentivePlan" selectedKey="{partnerAssignments>incentivePlan}" placeholder="{i18n>phSelectIncentivePlan}" width="100%"
                                            items="{planNames>/}">
                                            <items>
                                                <core:Item id="cellPAPlanItem" key="{planNames>key}" text="{planNames>text}" />
                                            </items>
                                        </ComboBox>
                                        <Button id="cellPADelete" icon="sap-icon://delete" type="Transparent" press="onDeleteAssignmentRow" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </content>
                </Page>
                <Page id="configDataSourcesPage" showHeader="false">
                    <content>
                        <VBox id="configDataSourcesHeaderVBox">
                            <HBox id="configDataSourcesHeaderHBox" class="sapUiSmallMargin" alignItems="Center">
                                <core:Icon id="configDataSourcesIcon" src="sap-icon://database" size="2rem" class="sapUiSmallMarginEnd" />
                                <Title id="configDataSourcesTitle" text="{i18n>navDataSources}" level="H2" />
                            </HBox>
                            <Text id="configDataSourcesDesc" text="{i18n>dataSourcesDescription}" class="sapUiSmallMarginBegin sapUiSmallMarginBottom" />
                        </VBox>
                        <SplitContainer id="configSplitContainer">
                            <masterPages>
                                <Page id="configMasterPage" title="{i18n>lblRepository}" showNavButton="false">
                                    <content>
                                        <List id="configDataSourceList" mode="SingleSelectMaster" selectionChange="onConfigDataSourceSelect">
                                            <items>
                                                <StandardListItem id="configListItemIncentiveTypes" title="{i18n>lblIncentiveTypes}" icon="sap-icon://list" type="Active">
                                                    <customData>
                                                        <core:CustomData id="configListItemIncentiveTypesKey" key="key" value="incentiveTypes" />
                                                    </customData>
                                                </StandardListItem>
                                                <StandardListItem id="configListItemEligibleTiers" title="{i18n>lblEligibleTiers}" icon="sap-icon://numbered-text" type="Active">
                                                    <customData>
                                                        <core:CustomData id="configListItemEligibleTiersKey" key="key" value="eligibleTiers" />
                                                    </customData>
                                                </StandardListItem>
                                                <StandardListItem id="configListItemPartnerTypes" title="{i18n>lblPartnerTypes}" icon="sap-icon://group" type="Active">
                                                    <customData>
                                                        <core:CustomData id="configListItemPartnerTypesKey" key="key" value="partnerTypes" />
                                                    </customData>
                                                </StandardListItem>
                                            </items>
                                        </List>
                                    </content>
                                </Page>
                            </masterPages>
                            <detailPages>
                                <Page id="configDetailEmptyPage" showHeader="false">
                                    <IllustratedMessage id="configDetailEmptyIllustration" illustrationType="sapIllus-SimpleNotFoundMagnifier" title="{i18n>selectDataSource}" description="{i18n>selectDataSourceDesc}" />
                                </Page>
                                <Page id="configIncentiveTypesPage">
                                    <customHeader>
                                        <OverflowToolbar id="incentiveTypesPageHeader">
                                            <Title id="incentiveTypesPageTitle" text="{i18n>lblIncentiveTypes} (0)" level="H5" />
                                            <ToolbarSpacer id="incentiveTypesToolbarSpacer" />
                                            <Button id="btnAddIncentiveType" text="{i18n>btnAdd}" icon="sap-icon://add" press="onAddIncentiveTypeRow" type="Transparent" />
                                            <Button id="btnSaveIncentiveTypes" text="{i18n>btnSave}" icon="sap-icon://save" press="onSaveIncentiveTypes" type="Success" />
                                        </OverflowToolbar>
                                    </customHeader>
                                    <content>
                                        <Table id="tblIncentiveTypes" items="{incentiveTypes>/}" growing="true" growingThreshold="50">
                                            <columns>
                                                <Column id="colIncentiveType">
                                                    <Text id="colIncentiveTypeHeader" text="{i18n>colIncentiveType}" />
                                                </Column>
                                                <Column id="colActive" width="120px" hAlign="Center">
                                                    <Text id="colActiveHeader" text="{i18n>colActive}" />
                                                </Column>
                                                <Column id="colDelete" width="80px" hAlign="Center">
                                                    <Text id="colDeleteHeader" text="" />
                                                </Column>
                                            </columns>
                                            <items>
                                                <ColumnListItem id="rowIncentiveType">
                                                    <cells>
                                                        <Input id="cellIncentiveType" value="{incentiveTypes>incentiveType}" placeholder="{i18n>phEnterIncentiveType}" />
                                                        <Switch id="cellActive" state="{incentiveTypes>active}" type="AcceptReject" />
                                                        <Button id="cellDelete" icon="sap-icon://delete" type="Transparent" press="onDeleteIncentiveTypeRow" />
                                                    </cells>
                                                </ColumnListItem>
                                            </items>
                                        </Table>
                                    </content>
                                </Page>
                                <Page id="configEligibleTiersPage">
                                    <customHeader>
                                        <OverflowToolbar id="eligibleTiersPageHeader">
                                            <Title id="eligibleTiersPageTitle" text="{i18n>lblEligibleTiers} (0)" level="H5" />
                                            <ToolbarSpacer id="eligibleTiersToolbarSpacer" />
                                            <Button id="btnAddEligibleTier" text="{i18n>btnAdd}" icon="sap-icon://add" press="onAddEligibleTierRow" type="Transparent" />
                                            <Button id="btnSaveEligibleTiers" text="{i18n>btnSave}" icon="sap-icon://save" press="onSaveEligibleTiers" type="Success" />
                                        </OverflowToolbar>
                                    </customHeader>
                                    <content>
                                        <Table id="tblEligibleTiers" items="{eligibleTiers>/}" growing="true" growingThreshold="50">
                                            <columns>
                                                <Column id="colETPartnerTier">
                                                    <Text id="colETPartnerTierHeader" text="{i18n>colPartnerTier}" />
                                                </Column>
                                                <Column id="colETRevenueBand">
                                                    <Text id="colETRevenueBandHeader" text="{i18n>colRevenueBand}" />
                                                </Column>
                                                <Column id="colETRegion">
                                                    <Text id="colETRegionHeader" text="{i18n>colRegion}" />
                                                </Column>
                                                <Column id="colETTier">
                                                    <Text id="colETTierHeader" text="{i18n>colTier}" />
                                                </Column>
                                                <Column id="colETEligibilityFlag" width="120px">
                                                    <Text id="colETEligibilityFlagHeader" text="{i18n>colEligibilityFlag}" />
                                                </Column>
                                                <Column id="colETDelete" width="60px" hAlign="Center">
                                                    <Text id="colETDeleteHeader" text="" />
                                                </Column>
                                            </columns>
                                            <items>
                                                <ColumnListItem id="rowEligibleTier">
                                                    <cells>
                                                        <Input id="cellETPartnerTier" value="{eligibleTiers>partnerTier}" placeholder="{i18n>phPartnerTier}" />
                                                        <Input id="cellETRevenueBand" value="{eligibleTiers>revenueBand}" placeholder="{i18n>phRevenueBand}" />
                                                        <Input id="cellETRegion" value="{eligibleTiers>region}" placeholder="{i18n>phRegion}" />
                                                        <Input id="cellETTier" value="{eligibleTiers>tier}" placeholder="{i18n>phTier}" />
                                                        <ComboBox id="cellETEligibilityFlag" selectedKey="{eligibleTiers>eligibilityFlag}" placeholder="{i18n>phEligibilityFlag}" width="100%">
                                                            <items>
                                                                <core:Item id="cellETFlagYes" key="Yes" text="Yes" />
                                                                <core:Item id="cellETFlagNo" key="No" text="No" />
                                                                <core:Item id="cellETFlagNA" key="N/A" text="N/A" />
                                                            </items>
                                                        </ComboBox>
                                                        <Button id="cellETDelete" icon="sap-icon://delete" type="Transparent" press="onDeleteEligibleTierRow" />
                                                    </cells>
                                                </ColumnListItem>
                                            </items>
                                        </Table>
                                    </content>
                                </Page>
                                <Page id="configPartnerTypesPage">
                                    <customHeader>
                                        <OverflowToolbar id="partnerTypesPageHeader">
                                            <Title id="partnerTypesPageTitle" text="{i18n>lblPartnerTypes} (0)" level="H5" />
                                            <ToolbarSpacer id="partnerTypesToolbarSpacer" />
                                            <Button id="btnAddPartnerType" text="{i18n>btnAdd}" icon="sap-icon://add" press="onAddPartnerTypeRow" type="Transparent" />
                                            <Button id="btnSavePartnerTypes" text="{i18n>btnSave}" icon="sap-icon://save" press="onSavePartnerTypes" type="Success" />
                                        </OverflowToolbar>
                                    </customHeader>
                                    <content>
                                        <Table id="tblPartnerTypes" items="{partnerTypes>/}" growing="true" growingThreshold="50">
                                            <columns>
                                                <Column id="colPTPartnerType">
                                                    <Text id="colPTPartnerTypeHeader" text="{i18n>colPartnerType}" />
                                                </Column>
                                                <Column id="colPTActive" width="120px" hAlign="Center">
                                                    <Text id="colPTActiveHeader" text="{i18n>colActive}" />
                                                </Column>
                                                <Column id="colPTDelete" width="80px" hAlign="Center">
                                                    <Text id="colPTDeleteHeader" text="" />
                                                </Column>
                                            </columns>
                                            <items>
                                                <ColumnListItem id="rowPartnerType">
                                                    <cells>
                                                        <Input id="cellPTPartnerType" value="{partnerTypes>partnerType}" placeholder="{i18n>phEnterPartnerType}" />
                                                        <Switch id="cellPTActive" state="{partnerTypes>active}" type="AcceptReject" />
                                                        <Button id="cellPTDelete" icon="sap-icon://delete" type="Transparent" press="onDeletePartnerTypeRow" />
                                                    </cells>
                                                </ColumnListItem>
                                            </items>
                                        </Table>
                                    </content>
                                </Page>
                            </detailPages>
                        </SplitContainer>
                    </content>
                </Page>
                <Page id="configCustomizationsPage" showHeader="false">
                    <content>
                        <VBox id="configCustomizationsHeaderVBox">
                            <HBox id="configCustomizationsHeaderHBox" class="sapUiSmallMargin" alignItems="Center">
                                <core:Icon id="configCustomizationsIcon" src="sap-icon://customize" size="2rem" class="sapUiSmallMarginEnd" />
                                <Title id="configCustomizationsTitle" text="{i18n>navCustomizations}" level="H2" />
                            </HBox>
                            <Text id="configCustomizationsDesc" text="{i18n>customizationsDescription}" class="sapUiSmallMarginBegin sapUiSmallMarginBottom" />
                        </VBox>
                        <SplitContainer id="customizationsSplitContainer">
                            <masterPages>
                                <Page id="customizationsMasterPage" title="{i18n>lblModules}" showNavButton="false">
                                    <content>
                                        <List id="customizationsModuleList" mode="SingleSelectMaster" selectionChange="onCustomizationModuleSelect">
                                            <items>
                                                <StandardListItem id="custListItemPartnerOnboarding" title="{i18n>navPartnerOnboarding}" icon="sap-icon://add-employee" type="Active">
                                                    <customData>
                                                        <core:CustomData id="custListItemPartnerOnboardingKey" key="key" value="partnerOnboarding" />
                                                    </customData>
                                                </StandardListItem>
                                            </items>
                                        </List>
                                    </content>
                                </Page>
                            </masterPages>
                            <detailPages>
                                <Page id="customizationsDetailEmptyPage" showHeader="false">
                                    <IllustratedMessage id="customizationsDetailEmptyIllustration" illustrationType="sapIllus-SimpleNotFoundMagnifier" title="{i18n>selectModule}" description="{i18n>selectModuleDesc}" />
                                </Page>
                                <Page id="customizationsPartnerOnboardingPage">
                                    <customHeader>
                                        <OverflowToolbar id="fieldCustomizationsPageHeader">
                                            <Title id="fieldCustomizationsTableTitle" text="{i18n>navPartnerOnboarding} (0)" level="H5" />
                                            <ToolbarSpacer id="fieldCustomizationsToolbarSpacer" />
                                            <Button id="btnSaveFieldCustomizations" text="{i18n>btnSave}" icon="sap-icon://save" press="onSaveFieldCustomizations" type="Success" />
                                        </OverflowToolbar>
                                    </customHeader>
                                    <content>
                                        <Table id="tblFieldCustomizations" items="{fieldCustomizations>/}" growing="true" growingThreshold="50">
                                            <columns>
                                                <Column id="colFCColumnName">
                                                    <Text id="colFCColumnNameHeader" text="{i18n>colColumnName}" />
                                                </Column>
                                                <Column id="colFCDefaultLabel">
                                                    <Text id="colFCDefaultLabelHeader" text="{i18n>colDefaultLabel}" />
                                                </Column>
                                                <Column id="colFCCustomLabel">
                                                    <Text id="colFCCustomLabelHeader" text="{i18n>colCustomLabel}" />
                                                </Column>
                                                <Column id="colFCEnabled" width="120px" hAlign="Center">
                                                    <Text id="colFCEnabledHeader" text="{i18n>colEnableDisable}" />
                                                </Column>
                                            </columns>
                                            <items>
                                                <ColumnListItem id="rowFieldCustomization">
                                                    <cells>
                                                        <Text id="cellFCColumnName" text="{fieldCustomizations>columnName}" />
                                                        <Text id="cellFCDefaultLabel" text="{fieldCustomizations>defaultLabel}" />
                                                        <Input id="cellFCCustomLabel" value="{fieldCustomizations>customLabel}" placeholder="{i18n>phCustomLabel}" />
                                                        <Switch id="cellFCEnabled" state="{fieldCustomizations>enabled}" type="AcceptReject" enabled="{= !${fieldCustomizations>fixed} }" />
                                                    </cells>
                                                </ColumnListItem>
                                            </items>
                                        </Table>
                                    </content>
                                </Page>
                            </detailPages>
                        </SplitContainer>
                    </content>
                </Page>
                <Page id="settingsPage" title="{i18n>navSettings}">
                    <IllustratedMessage id="settingsIllustration" illustrationType="sapIllus-EmptyList" title="{i18n>comingSoon}" description="{i18n>settingsComingSoonDesc}" />
                </Page>

            </NavContainer>
        </tnt:mainContents>

    </tnt:ToolPage>

</mvc:View>