<mvc:View controllerName="partnercommissions.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:u="sap.ui.unified">

    <tnt:ToolPage id="toolPage">

        <tnt:header>
            <tnt:ToolHeader id="toolHeader">
                <Button id="sideNavToggleBtn" icon="sap-icon://menu2" press="onToggleSideNav" type="Transparent" />
                <Title id="appTitleHeader" text="{i18n>appTitle}" level="H4" />
            </tnt:ToolHeader>
        </tnt:header>

        <tnt:sideContent>
            <tnt:SideNavigation id="sideNav" selectedKey="partnerOnboarding" itemSelect="onSideNavItemSelect">
                <tnt:NavigationList id="mainNavList">
                    <tnt:NavigationListItem id="navItemDashboard" text="{i18n>navDashboard}" icon="sap-icon://home" key="dashboard" />
                    <tnt:NavigationListItem id="navItemPartnerOnboarding" text="{i18n>navPartnerOnboarding}" icon="sap-icon://add-employee" key="partnerOnboarding" />
                    <tnt:NavigationListItem id="navItemIncentiveProgram" text="{i18n>navIncentiveProgramSetup}" icon="sap-icon://competitor" key="incentiveProgramSetup" />
                    <tnt:NavigationListItem id="navItemPartnerMappings" text="{i18n>navPartnerMappings}" icon="sap-icon://collaborate" key="partnerMappings" />
                    <tnt:NavigationListItem id="navItemPartnerHierarchy" text="{i18n>navPartnerHierarchySetup}" icon="sap-icon://org-chart" key="partnerHierarchySetup" />
                    <tnt:NavigationListItem id="navItemRiskScreening" text="{i18n>navRiskScreening}" icon="sap-icon://alert" key="riskScreening" />
                    <tnt:NavigationListItem id="navItemPaymentSchedule" text="{i18n>navPaymentScheduleSetup}" icon="sap-icon://date-time" key="paymentScheduleSetup" />
                    <tnt:NavigationListItem id="navItemDealRegistration" text="{i18n>navDealRegistration}" icon="sap-icon://sales-document" key="dealRegistration" />
                    <tnt:NavigationListItem id="navItemPaymentApproval" text="{i18n>navPaymentApproval}" icon="sap-icon://accept" key="paymentApproval" />
                </tnt:NavigationList>
                <tnt:fixedItem>
                    <tnt:NavigationList id="fixedNavList">
                        <tnt:NavigationListItem id="navItemConfigurations" text="{i18n>navConfigurations}" icon="sap-icon://wrench" expanded="false">
                            <tnt:NavigationListItem id="navItemConfigDataSources" text="{i18n>navDataSources}" icon="sap-icon://database" key="configDataSources" />
                            <tnt:NavigationListItem id="navItemConfigCustomizations" text="{i18n>navCustomizations}" icon="sap-icon://customize" key="configCustomizations" />
                        </tnt:NavigationListItem>
                        <tnt:NavigationListItem id="navItemSettings" text="{i18n>navSettings}" icon="sap-icon://action-settings" key="settings" />
                    </tnt:NavigationList>
                </tnt:fixedItem>
            </tnt:SideNavigation>
        </tnt:sideContent>

        <tnt:mainContents>
            <NavContainer id="mainContent">

                <!-- Partner Onboarding Page -->
                <Page id="partnerOnboardingPage" showHeader="false">
                    <content>
                        <VBox id="partnerOnboardingHeaderVBox">
                            <HBox id="partnerOnboardingHeaderHBox" class="sapUiSmallMargin" alignItems="Center">
                                <core:Icon id="partnerOnboardingIcon" src="sap-icon://add-employee" size="2rem" class="sapUiSmallMarginEnd" />
                                <Title id="partnerOnboardingTitle" text="{i18n>partnerOnboardingTitle}" level="H2" />
                            </HBox>
                            <Text id="partnerOnboardingDesc" text="{i18n>partnerOnboardingDescription}" class="sapUiSmallMarginBegin sapUiSmallMarginBottom" />
                        </VBox>
                        <IconTabBar id="onboardingTabBar" selectedKey="singleOnboarding" expandable="false">
                            <items>
                                <!-- Single Partner Registration Tab -->
                                <IconTabFilter id="tabSingleOnboarding" text="{i18n>tabPartnerRegistration}" key="singleOnboarding" icon="sap-icon://person-placeholder">
                                    <ScrollContainer id="formScrollContainer" vertical="true" horizontal="false">
                                        <VBox id="formOuterVBox" class="sapUiSmallMargin">
                                            <Panel id="panelRegistration" headerText="{i18n>panelPartnerRegistration}">
                                                <f:SimpleForm id="partnerForm"
                                                    editable="true"
                                                    layout="ResponsiveGridLayout"
                                                    labelSpanXL="3" labelSpanL="3" labelSpanM="3" labelSpanS="12"
                                                    emptySpanXL="4" emptySpanL="4" emptySpanM="4" emptySpanS="0"
                                                    columnsXL="1" columnsL="1" columnsM="1">

                                                    <Label id="lblPartnerType" text="{i18n>lblPartnerType}" required="true" />
                                                    <ComboBox id="cbPartnerType" placeholder="{i18n>phPartnerType}" width="100%">
                                                        <items>
                                                            <core:Item id="itemReseller" key="reseller" text="{i18n>partnerTypeReseller}" />
                                                            <core:Item id="itemReferral" key="referral" text="{i18n>partnerTypeReferral}" />
                                                            <core:Item id="itemDistributor" key="distributor" text="{i18n>partnerTypeDistributor}" />
                                                        </items>
                                                    </ComboBox>

                                                    <Label id="lblPartnerName" text="{i18n>lblPartnerName}" required="true" />
                                                    <Input id="inpPartnerName" placeholder="{i18n>phPartnerName}" width="100%" />

                                                    <Label id="lblCompanyRegNumber" text="{i18n>lblCompanyRegNumber}" />
                                                    <Input id="inpCompanyRegNumber" placeholder="{i18n>phCompanyRegNumber}" width="100%" />

                                                    <Label id="lblTaxId" text="{i18n>lblTaxId}" />
                                                    <Input id="inpTaxId" placeholder="{i18n>phTaxId}" width="100%" />

                                                    <Label id="lblCountry" text="{i18n>lblCountry}" required="true" />
                                                    <ComboBox id="cbCountry" placeholder="{i18n>phCountry}" width="100%">
                                                    </ComboBox>

                                                    <Label id="lblAddress" text="{i18n>lblAddress}" />
                                                    <Input id="inpAddress" placeholder="{i18n>phAddress}" width="100%" />

                                                    <Label id="lblIndustry" text="{i18n>lblIndustry}" />
                                                    <ComboBox id="cbIndustry" placeholder="{i18n>phIndustry}" width="100%">
                                                    </ComboBox>

                                                    <Label id="lblYearsInBusiness" text="{i18n>lblYearsInBusiness}" />
                                                    <HBox id="hboxBusinessDate">
                                                        <ComboBox id="cbYearsInBusinessMonth" placeholder="{i18n>phMonth}" width="30%">
                                                            <items>
                                                                <core:Item id="itemJan" key="01" text="January" />
                                                                <core:Item id="itemFeb" key="02" text="February" />
                                                                <core:Item id="itemMar" key="03" text="March" />
                                                                <core:Item id="itemApr" key="04" text="April" />
                                                                <core:Item id="itemMay" key="05" text="May" />
                                                                <core:Item id="itemJun" key="06" text="June" />
                                                                <core:Item id="itemJul" key="07" text="July" />
                                                                <core:Item id="itemAug" key="08" text="August" />
                                                                <core:Item id="itemSep" key="09" text="September" />
                                                                <core:Item id="itemOct" key="10" text="October" />
                                                                <core:Item id="itemNov" key="11" text="November" />
                                                                <core:Item id="itemDec" key="12" text="December" />
                                                            </items>
                                                        </ComboBox>
                                                        <ComboBox id="cbYearsInBusinessDay" placeholder="{i18n>phDay}" width="20%">
                                                        </ComboBox>
                                                        <ComboBox id="cbYearsInBusinessYear" placeholder="{i18n>phYear}" width="30%">
                                                        </ComboBox>
                                                    </HBox>

                                                    <Label id="lblAnnualRevenue" text="{i18n>lblAnnualRevenue}" />
                                                    <Input id="inpAnnualRevenue" placeholder="{i18n>phAnnualRevenue}" type="Number" width="100%" />

                                                    <Label id="lblNumberOfEmployees" text="{i18n>lblNumberOfEmployees}" />
                                                    <Input id="inpNumberOfEmployees" placeholder="{i18n>phNumberOfEmployees}" type="Number" width="100%" />

                                                </f:SimpleForm>
                                            </Panel>

                                            <OverflowToolbar id="formToolbar">
                                                <ToolbarSpacer id="formToolbarSpacer" />
                                                <Button id="btnClearForm" text="{i18n>btnClear}" press="onClearForm" type="Default" />
                                                <!-- <Button id="btnSaveDraft" text="{i18n>btnSaveDraft}" press="onSaveDraft" type="Default" /> -->
                                                <Button id="btnSubmitRiskScreening" text="{i18n>btnSubmit}" press="onSubmitRiskScreening" type="Emphasized" />
                                            </OverflowToolbar>
                                        </VBox>
                                    </ScrollContainer>
                                </IconTabFilter>

                                <!-- Bulk Onboarding Tab -->
                                <IconTabFilter id="tabBulkOnboarding" text="{i18n>tabBulkOnboarding}" key="bulkOnboarding" icon="sap-icon://upload-to-cloud">
                                    <VBox id="bulkOuterVBox" class="sapUiSmallMargin" alignItems="Start">
                                        <Panel id="panelBulkOnboarding" headerText="{i18n>panelBulkOnboarding}">
                                            <VBox id="bulkInnerVBox" class="sapUiSmallMargin">
                                                <Text id="bulkDescription" text="{i18n>bulkOnboardingDescription}" class="sapUiSmallMarginBottom" />
                                                <HBox id="hboxBulkButtons" class="sapUiSmallMarginTop">
                                                    <Button id="btnDownloadTemplate" text="{i18n>btnDownloadTemplate}" icon="sap-icon://download" press="onDownloadTemplate" type="Default" class="sapUiSmallMarginEnd" />
                                                    <u:FileUploader id="fileUploaderExcel" name="excelUpload" placeholder="{i18n>phUploadExcel}" fileType="xlsx,xls" change="onExcelFileChange" style="Emphasized" buttonText="{i18n>btnUploadExcel}" />
                                                </HBox>
                                            </VBox>
                                        </Panel>
                                    </VBox>
                                </IconTabFilter>
                            </items>
                        </IconTabBar>
                    </content>
                </Page>

                <!-- Placeholder pages for other sections -->
                <Page id="dashboardPage" title="{i18n>navDashboard}">
                    <IllustratedMessage id="dashboardIllustration" illustrationType="sapIllus-EmptyList" title="{i18n>comingSoon}" description="{i18n>dashboardComingSoonDesc}" />
                </Page>
                <Page id="incentiveProgramSetupPage" showHeader="false">
                    <content>
                        <VBox id="incentiveHeaderVBox">
                            <HBox id="incentiveHeaderHBox" class="sapUiSmallMargin" alignItems="Center">
                                <core:Icon id="incentiveHeaderIcon" src="sap-icon://competitor" size="2rem" class="sapUiSmallMarginEnd" />
                                <Title id="incentiveHeaderTitle" text="{i18n>incentiveProgramTitle}" level="H2" />
                            </HBox>
                            <Text id="incentiveHeaderDesc" text="{i18n>incentiveProgramDescription}" class="sapUiSmallMarginBegin sapUiSmallMarginBottom" />
                        </VBox>
                        <OverflowToolbar id="incentiveTableToolbar">
                            <Title id="incentiveTableTitle" text="Programs (0)" level="H5" />
                            <ToolbarSpacer id="incentiveTableToolbarSpacer" />
                            <Button id="btnAddIncentiveRow" text="{i18n>btnAdd}" icon="sap-icon://add" press="onAddIncentiveRow" type="Transparent" />
                            <Button id="btnSaveIncentivePrograms" text="{i18n>btnSave}" icon="sap-icon://save" press="onSaveIncentivePrograms" type="Success" />
                        </OverflowToolbar>
                        <Table id="tblIncentivePrograms" items="{incentivePrograms>/}" growing="true" growingThreshold="50">
                            <noData>
                                <IllustratedMessage id="incentiveProgramsEmptyIllustration" illustrationType="sapIllus-AddColumn" title="{i18n>noIncentiveProgramsTitle}" description="{i18n>noIncentiveProgramsDesc}" />
                            </noData>
                            <columns>
                                <Column id="colIPPlanName">
                                    <Text id="colIPPlanNameHeader" text="{i18n>lblProgramName}" />
                                </Column>
                                <Column id="colIPIncentiveType">
                                    <Text id="colIPIncentiveTypeHeader" text="{i18n>lblIncentiveType}" />
                                </Column>
                                <Column id="colIPEligibleTiers" width="140px">
                                    <Text id="colIPEligibleTiersHeader" text="{i18n>lblEligibleTiers}" />
                                </Column>
                                <Column id="colIPStartDate" width="150px">
                                    <Text id="colIPStartDateHeader" text="{i18n>phStartDate}" />
                                </Column>
                                <Column id="colIPEndDate" width="150px">
                                    <Text id="colIPEndDateHeader" text="{i18n>phEndDate}" />
                                </Column>
                                <Column id="colIPDealStage" width="150px">
                                    <Text id="colIPDealStageHeader" text="{i18n>lblDealStage}" />
                                </Column>
                                <Column id="colIPAttach" width="120px" hAlign="Center">
                                    <Text id="colIPAttachHeader" text="{i18n>lblAttachDocuments}" />
                                </Column>
                                <Column id="colIPDelete" width="60px" hAlign="Center">
                                    <Text id="colIPDeleteHeader" text="" />
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem id="rowIncentiveProgram">
                                    <cells>
                                        <ComboBox id="cellIPPlanName" selectedKey="{incentivePrograms>planName}" placeholder="{i18n>phProgramName}" width="100%"
                                            items="{planNames>/}">
                                            <items>
                                                <core:Item id="cellIPPlanNameItem" key="{planNames>key}" text="{planNames>text}" />
                                            </items>
                                        </ComboBox>
                                        <MultiComboBox id="cellIPIncentiveType" selectedKeys="{incentivePrograms>incentiveTypes}" placeholder="{i18n>phIncentiveType}" width="100%"
                                            items="{activeIncentiveTypes>/}">
                                            <items>
                                                <core:Item id="cellIPIncentiveTypeItem" key="{activeIncentiveTypes>key}" text="{activeIncentiveTypes>text}" />
                                            </items>
                                        </MultiComboBox>
                                        <ComboBox id="cellIPEligibleTier" selectedKey="{incentivePrograms>eligibleTier}" placeholder="{i18n>lblEligibleTiers}" width="100%">
                                            <items>
                                                <core:Item id="cellIPTierSilver" key="silver" text="{i18n>tierSilver}" />
                                                <core:Item id="cellIPTierGold" key="gold" text="{i18n>tierGold}" />
                                            </items>
                                        </ComboBox>
                                        <DatePicker id="cellIPStartDate" value="{incentivePrograms>startDate}" placeholder="{i18n>phStartDate}" width="100%" />
                                        <DatePicker id="cellIPEndDate" value="{incentivePrograms>endDate}" placeholder="{i18n>phEndDate}" width="100%" />
                                        <ComboBox id="cellIPDealStage" selectedKey="{incentivePrograms>dealStage}" placeholder="{i18n>phDealStage}" width="100%">
                                            <items>
                                                <core:Item id="cellIPDealStageCloseDate" key="closeDate" text="{i18n>dealStageCloseDate}" />
                                            </items>
                                        </ComboBox>
                                        <u:FileUploader id="cellIPFileUpload" name="incentiveDocUpload" buttonOnly="true" icon="sap-icon://upload" buttonText="" style="Transparent" change="onIncentiveFileChange" />
                                        <Button id="cellIPDelete" icon="sap-icon://delete" type="Transparent" press="onDeleteIncentiveRow" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </content>
                </Page>
                <Page id="riskScreeningPage" title="{i18n>navRiskScreening}">
                    <IllustratedMessage id="riskScreeningIllustration" illustrationType="sapIllus-EmptyList" title="{i18n>comingSoon}" description="{i18n>riskScreeningComingSoonDesc}" />
                </Page>
                <Page id="paymentScheduleSetupPage" title="{i18n>navPaymentScheduleSetup}">
                    <IllustratedMessage id="paymentScheduleIllustration" illustrationType="sapIllus-EmptyList" title="{i18n>comingSoon}" description="{i18n>paymentScheduleComingSoonDesc}" />
                </Page>
                <Page id="partnerHierarchySetupPage" title="{i18n>navPartnerHierarchySetup}">
                    <IllustratedMessage id="hierarchyIllustration" illustrationType="sapIllus-EmptyList" title="{i18n>comingSoon}" description="{i18n>hierarchyComingSoonDesc}" />
                </Page>
                <Page id="dealRegistrationPage" title="{i18n>navDealRegistration}">
                    <IllustratedMessage id="dealRegIllustration" illustrationType="sapIllus-EmptyList" title="{i18n>comingSoon}" description="{i18n>dealRegComingSoonDesc}" />
                </Page>
                <Page id="paymentApprovalPage" title="{i18n>navPaymentApproval}">
                    <IllustratedMessage id="paymentApprovalIllustration" illustrationType="sapIllus-EmptyList" title="{i18n>comingSoon}" description="{i18n>paymentApprovalComingSoonDesc}" />
                </Page>
                <Page id="partnerMappingsPage" title="{i18n>navPartnerMappings}">
                    <IllustratedMessage id="partnerMappingsIllustration" illustrationType="sapIllus-EmptyList" title="{i18n>comingSoon}" description="{i18n>partnerMappingsComingSoonDesc}" />
                </Page>
                <Page id="configDataSourcesPage" showHeader="false">
                    <content>
                        <VBox id="configDataSourcesHeaderVBox">
                            <HBox id="configDataSourcesHeaderHBox" class="sapUiSmallMargin" alignItems="Center">
                                <core:Icon id="configDataSourcesIcon" src="sap-icon://database" size="2rem" class="sapUiSmallMarginEnd" />
                                <Title id="configDataSourcesTitle" text="{i18n>navDataSources}" level="H2" />
                            </HBox>
                            <Text id="configDataSourcesDesc" text="{i18n>dataSourcesDescription}" class="sapUiSmallMarginBegin sapUiSmallMarginBottom" />
                        </VBox>
                        <SplitContainer id="configSplitContainer">
                            <masterPages>
                                <Page id="configMasterPage" title="{i18n>lblRepository}" showNavButton="false">
                                    <content>
                                        <List id="configDataSourceList" mode="SingleSelectMaster" selectionChange="onConfigDataSourceSelect">
                                            <items>
                                                <StandardListItem id="configListItemIncentiveTypes" title="{i18n>lblIncentiveTypes}" icon="sap-icon://list" type="Active">
                                                    <customData>
                                                        <core:CustomData id="configListItemIncentiveTypesKey" key="key" value="incentiveTypes" />
                                                    </customData>
                                                </StandardListItem>
                                            </items>
                                        </List>
                                    </content>
                                </Page>
                            </masterPages>
                            <detailPages>
                                <Page id="configDetailEmptyPage" showHeader="false">
                                    <IllustratedMessage id="configDetailEmptyIllustration" illustrationType="sapIllus-SimpleNotFoundMagnifier" title="{i18n>selectDataSource}" description="{i18n>selectDataSourceDesc}" />
                                </Page>
                                <Page id="configIncentiveTypesPage" title="{i18n>lblIncentiveTypes}">
                                    <headerContent>
                                        <OverflowToolbar id="incentiveTypesToolbar">
                                            <ToolbarSpacer id="incentiveTypesToolbarSpacer" />
                                            <Button id="btnAddIncentiveType" text="{i18n>btnAdd}" icon="sap-icon://add" press="onAddIncentiveTypeRow" type="Transparent" />
                                            <Button id="btnSaveIncentiveTypes" text="{i18n>btnSave}" icon="sap-icon://save" press="onSaveIncentiveTypes" type="Success" />
                                        </OverflowToolbar>
                                    </headerContent>
                                    <content>
                                        <Table id="tblIncentiveTypes" items="{incentiveTypes>/}" growing="true" growingThreshold="50">
                                            <columns>
                                                <Column id="colSno" width="80px">
                                                    <Text id="colSnoHeader" text="{i18n>colSno}" />
                                                </Column>
                                                <Column id="colIncentiveType">
                                                    <Text id="colIncentiveTypeHeader" text="{i18n>colIncentiveType}" />
                                                </Column>
                                                <Column id="colActive" width="120px" hAlign="Center">
                                                    <Text id="colActiveHeader" text="{i18n>colActive}" />
                                                </Column>
                                                <Column id="colDelete" width="80px" hAlign="Center">
                                                    <Text id="colDeleteHeader" text="" />
                                                </Column>
                                            </columns>
                                            <items>
                                                <ColumnListItem id="rowIncentiveType">
                                                    <cells>
                                                        <Text id="cellSno" text="{incentiveTypes>sno}" />
                                                        <Input id="cellIncentiveType" value="{incentiveTypes>incentiveType}" placeholder="{i18n>phEnterIncentiveType}" />
                                                        <Switch id="cellActive" state="{incentiveTypes>active}" type="AcceptReject" />
                                                        <Button id="cellDelete" icon="sap-icon://delete" type="Transparent" press="onDeleteIncentiveTypeRow" />
                                                    </cells>
                                                </ColumnListItem>
                                            </items>
                                        </Table>
                                    </content>
                                </Page>
                            </detailPages>
                        </SplitContainer>
                    </content>
                </Page>
                <Page id="configCustomizationsPage" title="{i18n>navCustomizations}">
                    <IllustratedMessage id="customizationsIllustration" illustrationType="sapIllus-EmptyList" title="{i18n>comingSoon}" description="{i18n>customizationsComingSoonDesc}" />
                </Page>
                <Page id="settingsPage" title="{i18n>navSettings}">
                    <IllustratedMessage id="settingsIllustration" illustrationType="sapIllus-EmptyList" title="{i18n>comingSoon}" description="{i18n>settingsComingSoonDesc}" />
                </Page>

            </NavContainer>
        </tnt:mainContents>

    </tnt:ToolPage>

</mvc:View>